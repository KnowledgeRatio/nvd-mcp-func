{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "environmentName": {
      "value": "${AZURE_ENV_NAME}"
    },
    "location": {
      "value": "${AZURE_LOCATION}"
    },
    "principalId": {
      "value": "${AZURE_PRINCIPAL_ID}"
    },
    "vnetEnabled": {
      "value": "${VNET_ENABLED}"
    },
    "nvdApiKey": {
      "value": "${NVD_API_KEY}"
    },
    "entraAppClientId": {
      "value": "${ENTRA_APP_CLIENT_ID}"
    },
    "mcpUnauthenticated": {
      "value": "${MCP_UNAUTHENTICATED_ACCESS}"
    },
    "resourceGroupName": {
      "value": "${AZURE_RESOURCE_GROUP_NAME}"
    },
    "apiServiceName": {
      "value": "${AZURE_FUNCTION_APP_NAME}"
    },
    "appServicePlanName": {
      "value": "${AZURE_APP_SERVICE_PLAN_NAME}"
    },
    "keyVaultCustomName": {
      "value": "${AZURE_KEY_VAULT_NAME}"
    },
    "storageAccountName": {
      "value": "${AZURE_STORAGE_ACCOUNT_NAME}"
    },
    "logAnalyticsName": {
      "value": "${AZURE_LOG_ANALYTICS_NAME}"
    },
    "applicationInsightsName": {
      "value": "${AZURE_APP_INSIGHTS_NAME}"
    },
    "vNetName": {
      "value": "${AZURE_VNET_NAME}"
    },
    "apiUserAssignedIdentityName": {
      "value": "${AZURE_IDENTITY_NAME}"
    }
  }
}